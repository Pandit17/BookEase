# =========================================================
# SERVER CONFIGURATION
# =========================================================
PORT=5000

# =========================================================
# DATABASE CONNECTION STRING (MongoDB local)
# =========================================================
MONGO_URI=mongodb://127.0.0.1:27017/bookease

# =========================================================
# JWT AUTH CONFIG
# =========================================================
JWT_SECRET=your_secret_key
JWT_EXPIRE=7d

# =========================================================
# PAYPAL CONFIG
# - Client ID is used in frontend (PayPal SDK)
# - Secret is used in backend (server-side payments)
# =========================================================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret